{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dotnet: clean",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "${workspaceFolder}/src/XtremeIdiots.Portal.Repository.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/XtremeIdiots.Portal.Repository.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "dependsOn": "dotnet: clean",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: test",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/src/XtremeIdiots.Portal.Repository.sln",
                "--filter",
                "FullyQualifiedName!~IntegrationTests",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: test-integration",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/src/XtremeIdiots.Portal.Repository.sln",
                "--filter",
                "FullyQualifiedName~IntegrationTests",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "group": {
                "kind": "test"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: format",
            "command": "dotnet",
            "type": "process",
            "args": [
                "format",
                "${workspaceFolder}/src/XtremeIdiots.Portal.Repository.sln",
                "--verify-no-changes"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: clean-release",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "--configuration",
                "Release",
                "${workspaceFolder}/src/XtremeIdiots.Portal.Repository.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "--configuration",
                "Release",
                "${workspaceFolder}/src/XtremeIdiots.Portal.Repository.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "dependsOn": "dotnet: clean-release",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/src/XtremeIdiots.Portal.Repository.sln"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}